rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCTION: HUBINTA ADMIN-KA ---
    function isAdmin() {
       return request.auth != null && request.auth.token.email in ['omermohamed1872@gmail.com', 'ebalamiservices@gmail.com'];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- EXPENSES ---
    match /expenses/{expenseId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if (request.auth.uid == resource.data.ownerId) || isAdmin();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notificationId} {
      allow read: if resource.data.target == 'all' || isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin();
    }

    // ==========================================================
    // 1. DALABYADA QABYADA AH (DRAFTS) - HALKAN AYAA CILADU KU JIRTAY
    // ==========================================================
    // Xalka: Waa inaan ogolaanaa "delete" si App-ku u nadiifiyo qabyada markuu diro.
    
    match /dalabyadaAanDhamaystirnayn/{docId} {
      // Fasax wax walba (Create, Read, Update, DELETE)
      // Sababtoo ah kuwani waa qabyo, App-ku waa inuu tirtiri karaa markuu dhammeeyo.
      allow read, write, delete: if true;
    }

    // ==========================================================
    // 2. DALABYADA DHAMMAYSTIRAN (FINAL ORDERS)
    // ==========================================================
    
    match /dalabyadaDhamaystiran/{docId} {
      allow create: if isAdmin() || isOwner(request.resource.data.uid);
      allow read: if isAdmin() || isOwner(resource.data.uid);
      allow update: if isAdmin() || isOwner(resource.data.uid);
      allow delete: if isAdmin() || isOwner(resource.data.uid);
    }
  }
}
